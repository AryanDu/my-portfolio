# MongoDB connection string (MongoDB Atlas free tier works great)
# Example: mongodb+srv://username:password@cluster0.mongodb.net/portfolio
MONGO_URI=your_mongodb_connection_string_here

# Secret used to sign admin login tokens - make this long & random
JWT_SECRET=change_this_to_a_long_random_string

# The password YOU will use to log into the admin panel
# (this gets hashed on first server start, see config/seedAdmin.js)
ADMIN_USERNAME=aryan
ADMIN_PASSWORD=change_this_password

# Port the backend runs on
PORT=5000

# Comma-separated list of allowed frontend origins (for CORS)
CLIENT_ORIGIN=http://localhost:5173
